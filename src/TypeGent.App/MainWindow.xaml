<Window x:Class="TypeGent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TypeGent.App"
        mc:Ignorable="d"
        Title="TypeGent" Height="500" Width="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Text="Phase 4 debug. Edit the text, click &quot;Type test&quot;, then switch focus to your target window (e.g. Notepad) during the 3-second countdown. Typing uses the human engine (default 60 WPM, ~2% typo rate with immediate corrections); WPM / typo sliders arrive in Phase 5." />

        <TextBox Grid.Row="1"
                 x:Name="TextToType"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 Text="The quick brown fox jumps over the lazy dog. Pack my box with five dozen liquor jugs! TypeGent types like a human: with a natural rhythm, the occasional slip, and an immediate correction — then it keeps right on going." />

        <Button Grid.Row="2"
                x:Name="TypeButton"
                Content="Type test"
                Margin="0,8,0,0"
                Padding="14,6"
                HorizontalAlignment="Left"
                Click="TypeButton_Click" />

        <TextBlock Grid.Row="3"
                   x:Name="StatusText"
                   Margin="0,8,0,0"
                   Text="Idle." />
    </Grid>
</Window>
