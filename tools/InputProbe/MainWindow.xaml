<Window x:Class="InputProbe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InputProbe — Keystroke Verification Harness" Height="720" Width="900"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Instructions -->
            <RowDefinition Height="*" />
            <!-- Event log -->
            <RowDefinition Height="Auto" />
            <!-- Stats -->
            <RowDefinition Height="Auto" />
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Instructions + capture status -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,6">
                Click below, then have TypeGent type into this window (Start with a 3-second countdown, or use the hotkey).
                Every KeyDown/KeyUp is timestamped and logged below. Save to CSV when done to analyze dwell/flight.
            </TextBlock>
            <TextBlock x:Name="CaptureStatus" FontWeight="SemiBold" />
        </StackPanel>

        <!-- Event log -->
        <DockPanel Grid.Row="1" LastChildFill="True">
            <TextBlock DockPanel.Dock="Top" Text="Event log (VK, event, time_ms):" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ListView x:Name="EventLog" FontFamily="Consolas" FontSize="12" />
        </DockPanel>

        <!-- Stats summary -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="1" Padding="10" Margin="0,10,0,10" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="Measured distributions" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock x:Name="StatsText" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Save CSV…" Padding="16,6" MinWidth="100" Click="SaveCsv_Click" />
            <Button Content="Clear" Padding="16,6" MinWidth="80" Margin="10,0,0,0" Click="Clear_Click" />
            <TextBlock x:Name="SaveStatus" VerticalAlignment="Center" Margin="14,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
